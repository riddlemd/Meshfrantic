@inherits LayoutComponentBase
@inject MeshtasticService Mesh
@inject ThemeService ThemeService
@inject IJSRuntime JS
@implements IDisposable

<div class="page">
    <!-- Header Section -->
    <div class="layout-header">
        <div class="sidebar">
            <div class="logo">://MESHFRANTIC</div>
        </div>
        <div class="header">
            <div class="connection-bar">
                <div class="connection-bar__left d-flex align-items-center gap-2">
                    <div class="status-badge @(Mesh.IsConnected ? "status-badge--connected" : "status-badge--disconnected")">
                        <span class="status-badge__dot"></span>
                        @if (Mesh.IsConnected)
                        {
                            var nodeInfo = Mesh.Container.MyNodeInfo;
                            var nodeNum = nodeInfo?.MyNodeNum ?? 0;
                            var name = nodeNum > 0 ? Mesh.Container.GetNodeDisplayName(nodeNum) : Mesh.ConnectedPort;
                            <span>@name</span>
                        }
                        else if (Mesh.IsRebooting)
                        {
                            <span>Reconnecting...</span>
                        }
                        else
                        {
                            <span>Disconnected</span>
                        }
                    </div>
                </div>

                <CurrentDateTime />

                <div class="connection-bar__right d-flex align-items-center gap-2">
                    <span class="theme-control__label">Theme</span>
                    <select class="form-select form-select-sm theme-control__select" value="@_selectedTheme" @onchange="OnThemeChanged">
                        @foreach (var theme in ThemeService.Themes)
                        {
                            <option value="@theme.Key">@theme.Value</option>
                        }
                    </select>

                    <select class="form-select form-select-sm" style="width:auto"
                            value="@_useTcp.ToString().ToLower()"
                            @onchange="OnConnectionModeChanged"
                            disabled="@(Mesh.IsConnected || Mesh.IsRebooting)">
                        <option value="false">Serial</option>
                        <option value="true">TCP</option>
                    </select>

                    @if (!_useTcp)
                    {
                        <span class="port-control__label">Port</span>
                        <select class="form-select form-select-sm port-control__select"
                                @bind="_selectedPort"
                                disabled="@(Mesh.IsConnected || Mesh.IsRebooting)">
                            <option value="">-- Select port --</option>
                            @foreach (var port in Mesh.AvailablePorts)
                            {
                                <option value="@port">@port</option>
                            }
                        </select>

                        <button class="btn btn-sm btn-outline-secondary"
                                @onclick="RefreshPorts"
                                disabled="@(Mesh.IsConnected || Mesh.IsRebooting)"
                                title="Refresh ports">
                            &#8635;
                        </button>
                    }
                    else
                    {
                        <input class="form-control form-control-sm" style="width:130px"
                               placeholder="host"
                               @bind="_tcpHost"
                               @bind:after="SaveTcpPrefs"
                               disabled="@(Mesh.IsConnected || Mesh.IsRebooting)" />
                        <input class="form-control form-control-sm" style="width:70px"
                               type="number"
                               @bind="_tcpPort"
                               @bind:after="SaveTcpPrefs"
                               disabled="@(Mesh.IsConnected || Mesh.IsRebooting)" />
                    }

                    @if (!Mesh.IsConnected && !Mesh.IsRebooting)
                    {
                        <button class="btn btn-sm btn-success"
                                @onclick="Connect"
                                disabled="@((_useTcp ? string.IsNullOrWhiteSpace(_tcpHost) : string.IsNullOrEmpty(_selectedPort)) || _busy)">
                            @if (_busy) { <span>Connecting...</span> } else { <span>Connect</span> }
                        </button>
                    }
                    else if (Mesh.IsRebooting)
                    {
                        <button class="btn btn-sm btn-success" disabled>Reconnecting...</button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-danger"
                                @onclick="Disconnect"
                                disabled="@_busy">
                            Disconnect
                        </button>
                    }

                    @if (Mesh.IsConnected && OwnBattery is > 0 and var bat)
                    {
                        <div class="battery" style="color: @BatteryColor(bat)" title="Battery: @bat%">
                            <span class="battery__icon">
                                <span class="battery__fill" style="width: @bat%"></span>
                            </span>
                            <span class="battery__percentage">@bat%</span>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <span class="text-danger ms-2 small">@_error</span>
                }
            </div>
        </div>
    </div>

    <!-- Body Section -->
    <div class="layout-body">
        <div class="sidebar">
            <NavMenu />
        </div>
        <article class="content">
            @Body
        </article>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>

@code {
    private string _selectedPort = string.Empty;
    private string _selectedTheme = "terminal-green";
    private bool _busy;
    private string _error = string.Empty;
    private bool _themeLoaded = false;
    private bool _useTcp = false;
    private string _tcpHost = "localhost";
    private int _tcpPort = 4403;

    private uint OwnNodeNum => Mesh.Container.MyNodeInfo?.MyNodeNum ?? 0;

    private uint? OwnBattery =>
        OwnNodeNum > 0
            ? Mesh.Container.Nodes.FirstOrDefault(n => n.Num == OwnNodeNum)?.DeviceMetrics?.BatteryLevel
            : null;

    private static string BatteryColor(uint pct) => pct switch
    {
        >= 60 => "var(--mesh-primary-light)",
        >= 30 => "var(--mesh-warning)",
        _     => "var(--mesh-danger)"
    };

    protected override void OnInitialized()
    {
        if (Mesh.IsConnected && Mesh.ConnectedPort != null)
            _selectedPort = Mesh.ConnectedPort;
        Mesh.StateChanged += OnStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        string? mode = null;

        if (firstRender && !_themeLoaded)
        {
            _selectedTheme = await JS.InvokeAsync<string>("getTheme");

            mode = await JS.InvokeAsync<string?>("localStorage.getItem", "mesh_connection_mode");
            if (mode == "tcp")
            {
                _useTcp = true;
                var host = await JS.InvokeAsync<string?>("localStorage.getItem", "mesh_tcp_host");
                var port = await JS.InvokeAsync<string?>("localStorage.getItem", "mesh_tcp_port");
                if (!string.IsNullOrWhiteSpace(host)) _tcpHost = host;
                if (int.TryParse(port, out var p)) _tcpPort = p;
            }

            _themeLoaded = true;
            StateHasChanged();
        }

        if (firstRender && mode == "serial" && !Mesh.IsConnected && Mesh.AvailablePorts.Count == 1)
        {
            _selectedPort = Mesh.AvailablePorts[0];
            await Connect();
        }
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private void RefreshPorts()
    {
        Mesh.RefreshPorts();
        _selectedPort = string.Empty;
    }

    private async Task Connect()
    {
        _busy = true;
        _error = string.Empty;
        try
        {
            if (_useTcp)
                await Mesh.ConnectTcpAsync(_tcpHost, _tcpPort);
            else
                await Mesh.ConnectAsync(_selectedPort);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task Disconnect()
    {
        _busy = true;
        try
        {
            await Mesh.DisconnectAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task OnConnectionModeChanged(ChangeEventArgs e)
    {
        _useTcp = e.Value?.ToString() == "true";
        await JS.InvokeVoidAsync("localStorage.setItem", "mesh_connection_mode", _useTcp ? "tcp" : "serial");
    }

    private async Task SaveTcpPrefs()
    {
        await JS.InvokeVoidAsync("localStorage.setItem", "mesh_tcp_host", _tcpHost);
        await JS.InvokeVoidAsync("localStorage.setItem", "mesh_tcp_port", _tcpPort.ToString());
    }

    private async Task OnThemeChanged(ChangeEventArgs e)
    {
        var theme = e.Value?.ToString() ?? "terminal-green";
        _selectedTheme = theme;
        ThemeService.SetTheme(theme);
        await JS.InvokeVoidAsync("setTheme", theme);
    }

    public void Dispose() => Mesh.StateChanged -= OnStateChanged;
}
