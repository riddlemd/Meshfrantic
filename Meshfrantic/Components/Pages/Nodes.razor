@page "/nodes"
@inject MeshtasticService Mesh
@implements IDisposable

<PageTitle>Meshfrantic — Nodes</PageTitle>

<div class="px-4">
<h2 class="mb-3">Nodes</h2>

@if (!Mesh.IsConnected)
{
    <div class="alert alert-info">Connect to a device to see the node list.</div>
}
else if (!Mesh.Container.Nodes.Any())
{
    <div class="alert alert-secondary">Waiting for node data from device...</div>
}
else
{
    var ownNodeNum = Mesh.Container.MyNodeInfo?.MyNodeNum ?? 0;
    var sorted = Mesh.Container.Nodes.OrderBy(n => n.Num == ownNodeNum ? 0 : 1).ToList();
    var page = PagedNodes(sorted);

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Node ID</th>
                    <th>Long Name</th>
                    <th>Short</th>
                    <th>Hardware</th>
                    <th>Last Heard</th>
                    <th>SNR</th>
                    <th>Hops</th>
                    <th>Battery</th>
                    <th>Position</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var node in page)
                {
                    var isOwn = node.Num == ownNodeNum;
                    var hasPosition = node.Position != null &&
                                      (node.Position.LatitudeI != 0 || node.Position.LongitudeI != 0);
                    <tr>
                        <td>
                            <code>!@node.Num.ToString("x8")</code>
                            @if (isOwn)
                            {
                                <span class="badge bg-primary ms-1">You</span>
                            }
                        </td>
                        <td>@(node.User?.LongName ?? "—")</td>
                        <td><strong>@(node.User?.ShortName ?? "—")</strong></td>
                        <td><span class="text-muted small">@(node.User?.HwModel.ToString() ?? "—")</span></td>
                        <td>
                            @if (node.LastHeard > 0)
                            {
                                var heard = DateTimeOffset.FromUnixTimeSeconds(node.LastHeard).LocalDateTime;
                                <span title="@heard.ToString("g")">@TimeAgo(heard)</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if (node.Snr != 0)
                            {
                                <span class="@SnrClass(node.Snr)">@node.Snr.ToString("F1") dB</span>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td>
                            @if (node.HopsAway > 0) { <span>@node.HopsAway</span> }
                            else if (isOwn) { <span class="text-muted">local</span> }
                            else { <span class="text-muted">direct</span> }
                        </td>
                        <td>
                            @if (node.DeviceMetrics?.BatteryLevel is > 0 and var bat)
                            {
                                <span class="@BatteryClass(bat)">@bat%</span>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td>
                            @if (hasPosition)
                            {
                                var lat = node.Position!.LatitudeI / 1e7;
                                var lon = node.Position!.LongitudeI / 1e7;
                                <span class="text-muted small">@lat.ToString("F4"), @lon.ToString("F4")</span>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td class="text-end">
                            <a class="action-link me-2" @onclick="() => ToggleExpand(node.Num)" @onclick:preventDefault>
                                @(_expandedNode == node.Num ? "▲" : "▼")
                            </a>
                            @if (!isOwn)
                            {
                                @if (_confirmDeleteNum == node.Num)
                                {
                                    <span class="me-1 small text-danger">Remove?</span>
                                    <a class="action-link danger me-2" @onclick="() => ConfirmRemove(node.Num)" @onclick:preventDefault>Yes</a>
                                    <a class="action-link" @onclick="CancelRemove" @onclick:preventDefault>No</a>
                                }
                                else
                                {
                                    <a class="action-link danger" @onclick="() => _confirmDeleteNum = node.Num" @onclick:preventDefault>Remove</a>
                                }
                            }
                        </td>
                    </tr>
                    @if (_expandedNode == node.Num)
                    {
                        <tr class="node-expand-row">
                            <td colspan="10">
                                @{
                                    Mesh.NodeTelemetryMap.TryGetValue(node.Num, out var tel);
                                    Mesh.TracerouteResults.TryGetValue(node.Num, out var route);
                                }
                                <div class="node-expand-body">
                                    <div class="row g-3">
                                        <!-- Node info -->
                                        <div class="col-md-3">
                                            <div class="tel-group-label">Node Info</div>
                                            <div class="tel-row"><span>Node ID</span><strong>!@node.Num.ToString("x8")</strong></div>
                                            @if (node.User != null)
                                            {
                                                <div class="tel-row"><span>Long Name</span><strong>@node.User.LongName</strong></div>
                                                <div class="tel-row"><span>Short Name</span><strong>@node.User.ShortName</strong></div>
                                                <div class="tel-row"><span>Hardware</span><strong>@node.User.HwModel</strong></div>
                                            }
                                            @if (node.LastHeard > 0)
                                            {
                                                var heard = DateTimeOffset.FromUnixTimeSeconds(node.LastHeard).LocalDateTime;
                                                <div class="tel-row"><span>Last Heard</span><strong>@TimeAgo(heard)</strong></div>
                                            }
                                            <div class="tel-row"><span>Hops Away</span><strong>@node.HopsAway</strong></div>
                                            @if (node.Snr != 0)
                                            {
                                                <div class="tel-row"><span>SNR</span><strong class="@SnrClass(node.Snr)">@node.Snr.ToString("F1") dB</strong></div>
                                            }
                                        </div>

                                        <!-- Position -->
                                        @if (node.Position != null && (node.Position.LatitudeI != 0 || node.Position.LongitudeI != 0))
                                        {
                                            <div class="col-md-3">
                                                <div class="tel-group-label">Position</div>
                                                <div class="tel-row"><span>Latitude</span><strong>@((node.Position.LatitudeI / 1e7).ToString("F5"))</strong></div>
                                                <div class="tel-row"><span>Longitude</span><strong>@((node.Position.LongitudeI / 1e7).ToString("F5"))</strong></div>
                                                <div class="tel-row"><span>Altitude</span><strong>@node.Position.Altitude m</strong></div>
                                            </div>
                                        }

                                        <!-- Telemetry -->
                                        @if (tel != null)
                                        {
                                            <div class="col-md-3">
                                                <div class="tel-group-label">Telemetry</div>
                                                @if (tel.BatteryLevel.HasValue)
                                                {
                                                    <div class="tel-row"><span>Battery</span><strong class="@BatteryClass(tel.BatteryLevel.Value)">@tel.BatteryLevel.Value%</strong></div>
                                                }
                                                @if (tel.Voltage.HasValue)
                                                {
                                                    <div class="tel-row"><span>Voltage</span><strong>@tel.Voltage.Value.ToString("F2") V</strong></div>
                                                }
                                                @if (tel.ChannelUtilization.HasValue)
                                                {
                                                    <div class="tel-row"><span>Ch Util</span><strong>@tel.ChannelUtilization.Value.ToString("F1")%</strong></div>
                                                }
                                                @if (tel.AirUtilTx.HasValue)
                                                {
                                                    <div class="tel-row"><span>Air Util TX</span><strong>@tel.AirUtilTx.Value.ToString("F1")%</strong></div>
                                                }
                                                @if (tel.UptimeSeconds.HasValue)
                                                {
                                                    <div class="tel-row"><span>Uptime</span><strong>@FormatUptime(tel.UptimeSeconds.Value)</strong></div>
                                                }
                                                @if (tel.Temperature.HasValue)
                                                {
                                                    <div class="tel-row"><span>Temp</span><strong>@tel.Temperature.Value.ToString("F1") °C</strong></div>
                                                }
                                                @if (tel.RelativeHumidity.HasValue)
                                                {
                                                    <div class="tel-row"><span>Humidity</span><strong>@tel.RelativeHumidity.Value.ToString("F1")%</strong></div>
                                                }
                                                @if (tel.BarometricPressure.HasValue)
                                                {
                                                    <div class="tel-row"><span>Pressure</span><strong>@tel.BarometricPressure.Value.ToString("F1") hPa</strong></div>
                                                }
                                                <div class="tel-row"><span style="font-size:0.65rem">updated</span><strong style="font-size:0.65rem">@tel.LastUpdated.ToString("HH:mm:ss")</strong></div>
                                            </div>
                                        }

                                        <!-- Traceroute -->
                                        @if (!isOwn)
                                        {
                                            <div class="col-md-3">
                                                <div class="tel-group-label">Traceroute</div>
                                                @if (route != null)
                                                {
                                                    <div class="traceroute-path">
                                                        <div class="traceroute-hop">@Mesh.Container.GetNodeDisplayName(Mesh.Container.MyNodeInfo?.MyNodeNum ?? 0) (you)</div>
                                                        @foreach (var hop in route.SkipLast(1))
                                                        {
                                                            <div class="traceroute-hop">@Mesh.Container.GetNodeDisplayName(hop)</div>
                                                        }
                                                        <div class="traceroute-hop traceroute-hop--dest">@Mesh.Container.GetNodeDisplayName(node.Num)</div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="text-muted small mb-2">No route data yet.</div>
                                                }
                                                <button class="btn btn-sm btn-outline-secondary mt-1"
                                                        @onclick="() => SendTraceroute(node.Num)"
                                                        disabled="@(_tracerouteInProgress == node.Num)">
                                                    @(_tracerouteInProgress == node.Num ? "Sending..." : "Request Traceroute")
                                                </button>
                                                @if (!string.IsNullOrEmpty(_tracerouteError))
                                                {
                                                    <div class="text-danger small mt-1">@_tracerouteError</div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="nodes-footer">
        <span class="text-muted small">
            @sorted.Count node(s) &mdash; showing @((_currentPage - 1) * PageSize + 1)&ndash;@(Math.Min(_currentPage * PageSize, sorted.Count))
        </span>
        @if (TotalPages(sorted.Count) > 1)
        {
            <nav class="pagination-nav">
                <a class="page-link @(_currentPage == 1 ? "disabled" : "")"
                   @onclick="() => GoToPage(1)" @onclick:preventDefault>&#171;</a>
                <a class="page-link @(_currentPage == 1 ? "disabled" : "")"
                   @onclick="() => GoToPage(_currentPage - 1)" @onclick:preventDefault>&#8249;</a>

                @foreach (var p in PageNumbers(sorted.Count))
                {
                    <a class="page-link @(p == _currentPage ? "active" : "")"
                       @onclick="() => GoToPage(p)" @onclick:preventDefault>@p</a>
                }

                <a class="page-link @(_currentPage == TotalPages(sorted.Count) ? "disabled" : "")"
                   @onclick="() => GoToPage(_currentPage + 1)" @onclick:preventDefault>&#8250;</a>
                <a class="page-link @(_currentPage == TotalPages(sorted.Count) ? "disabled" : "")"
                   @onclick="() => GoToPage(TotalPages(sorted.Count))" @onclick:preventDefault>&#187;</a>
            </nav>
        }
    </div>
}
</div>

@code {
    private const int PageSize = 20;
    private int _currentPage = 1;
    private uint? _confirmDeleteNum;
    private uint? _expandedNode;
    private uint? _tracerouteInProgress;
    private string _tracerouteError = string.Empty;

    private void ToggleExpand(uint nodeNum) =>
        _expandedNode = _expandedNode == nodeNum ? null : nodeNum;

    private async Task SendTraceroute(uint nodeNum)
    {
        _tracerouteInProgress = nodeNum;
        _tracerouteError = string.Empty;
        try
        {
            await Mesh.RequestTracerouteAsync(nodeNum);
        }
        catch (Exception ex)
        {
            _tracerouteError = ex.Message;
        }
        finally
        {
            _tracerouteInProgress = null;
        }
    }

    protected override void OnInitialized() => Mesh.StateChanged += OnStateChanged;

    private void OnStateChanged()
    {
        // If nodes shrink, clamp page to valid range
        var total = Mesh.Container.Nodes.Count;
        var max = Math.Max(1, (int)Math.Ceiling(total / (double)PageSize));
        if (_currentPage > max) _currentPage = max;
        InvokeAsync(StateHasChanged);
    }

    private void CancelRemove() => _confirmDeleteNum = null;

    private async Task ConfirmRemove(uint nodeNum)
    {
        _confirmDeleteNum = null;
        await Mesh.RemoveNodeAsync(nodeNum);
    }

    private void GoToPage(int page)
    {
        var total = Mesh.Container.Nodes.Count;
        var max = TotalPages(total);
        _currentPage = Math.Clamp(page, 1, Math.Max(1, max));
    }

    private IEnumerable<Meshtastic.Protobufs.NodeInfo> PagedNodes(List<Meshtastic.Protobufs.NodeInfo> nodes)
        => nodes.Skip((_currentPage - 1) * PageSize).Take(PageSize);

    private int TotalPages(int count) => Math.Max(1, (int)Math.Ceiling(count / (double)PageSize));

    private IEnumerable<int> PageNumbers(int count)
    {
        var total = TotalPages(count);
        var start = Math.Max(1, _currentPage - 2);
        var end = Math.Min(total, start + 4);
        start = Math.Max(1, end - 4);
        return Enumerable.Range(start, end - start + 1);
    }

    public void Dispose() => Mesh.StateChanged -= OnStateChanged;

    private static string TimeAgo(DateTime dt)
    {
        var diff = DateTime.Now - dt;
        if (diff.TotalSeconds < 60) return $"{(int)diff.TotalSeconds}s ago";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        return dt.ToString("MM/dd HH:mm");
    }

    private static string SnrClass(float snr) => snr switch
    {
        >= 5 => "text-success",
        >= 0 => "text-warning",
        _ => "text-danger"
    };

    private static string FormatUptime(uint secs)
    {
        if (secs < 60) return $"{secs}s";
        if (secs < 3600) return $"{secs / 60}m {secs % 60}s";
        return $"{secs / 3600}h {secs % 3600 / 60}m";
    }

    private static string BatteryClass(uint pct) => pct switch
    {
        >= 60 => "text-success",
        >= 30 => "text-warning",
        _ => "text-danger"
    };
}
